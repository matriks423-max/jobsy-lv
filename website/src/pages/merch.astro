---
import Layout from '../layouts/Layout.astro';
import { readFileSync, existsSync } from 'fs';
import { join } from 'path';

const contentDir = join(process.cwd(), 'public/content');

function loadJSON(filename: string, fallback: any) {
  const path = join(contentDir, filename);
  if (!existsSync(path)) return fallback;
  try {
    return JSON.parse(readFileSync(path, 'utf-8'));
  } catch {
    return fallback;
  }
}

const merch = loadJSON('merch.json', { products: [], store_url: '', last_updated_episode: 0 });
const products: any[] = merch.products ?? [];
const storeUrl: string = merch.store_url ?? '';
const lastEpisode: number = merch.last_updated_episode ?? 0;
const hasProducts = products.length > 0;
---

<Layout
  title="Merch"
  description="Arion World official merch — t-shirts, posters, and mugs featuring artwork from key episodes. Print-on-demand, ships worldwide."
>

  <!-- Page header -->
  <section class="relative pt-24 pb-16 px-6 text-center">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-gold/30 via-transparent to-transparent pointer-events-none"></div>
    <p class="font-mono text-xs tracking-[0.4em] uppercase text-text-dim mb-4">Arion World</p>
    <h1 class="font-display text-5xl md:text-6xl text-gold tracking-widest uppercase mb-4">
      Merch
    </h1>
    <p class="text-text-muted italic max-w-lg mx-auto">
      Own a piece of the story. Print-on-demand — made only when you order, ships worldwide.
    </p>
    {lastEpisode > 0 && (
      <p class="text-text-dim text-xs mt-4 tracking-wider">
        Updated through Episode {lastEpisode}
      </p>
    )}
  </section>

  {hasProducts ? (
    <>
      <!-- Product grid -->
      <section class="max-w-6xl mx-auto px-6 pb-24">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-white/5">
          {products.map((product: any) => (
            <a
              href={product.url || storeUrl || '#'}
              target={product.url ? '_blank' : undefined}
              rel={product.url ? 'noopener noreferrer' : undefined}
              class="bg-ash p-0 hover:bg-mist transition-colors group block overflow-hidden"
            >
              {/* Product image */}
              <div class="aspect-square bg-void/60 overflow-hidden">
                {product.image_url ? (
                  <img
                    src={product.image_url}
                    alt={product.name}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center">
                    <span class="font-display text-text-dim text-xs tracking-widest uppercase">
                      {product.type ?? 'Product'}
                    </span>
                  </div>
                )}
              </div>

              {/* Product info */}
              <div class="p-6">
                {product.episode_number && (
                  <p class="font-mono text-xs text-text-dim tracking-widest uppercase mb-1">
                    Episode {product.episode_number}
                  </p>
                )}
                <h3 class="font-display text-text-primary group-hover:text-gold transition-colors mb-2 leading-tight">
                  {product.name}
                </h3>
                {product.type && (
                  <p class="text-text-dim text-xs tracking-wider uppercase mb-3">{product.type}</p>
                )}
                {product.price && (
                  <p class="text-gold text-sm font-display tracking-wide">{product.price}</p>
                )}
              </div>
            </a>
          ))}
        </div>

        {storeUrl && (
          <div class="text-center mt-12">
            <a
              href={storeUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="px-8 py-3 border border-gold/30 text-gold font-display tracking-widest uppercase text-sm hover:border-gold hover:text-gold-bright transition-colors inline-block"
            >
              View Full Store →
            </a>
          </div>
        )}
      </section>
    </>
  ) : (
    <!-- Coming soon state -->
    <section class="max-w-2xl mx-auto px-6 pb-32 text-center">
      <div class="border border-white/5 bg-ash p-12">
        <p class="font-display text-gold tracking-[0.3em] uppercase text-xs mb-6">
          Coming Soon
        </p>
        <p class="text-text-muted leading-relaxed mb-8">
          Episode merch is in production. T-shirts, posters, and mugs featuring artwork from
          key scenes will appear here as episodes release.
        </p>
        <p class="text-text-dim text-xs italic mb-10">
          "The image that haunts you from Episode 1 will mean something very different in Episode 100."
        </p>

        <!-- Email signup prompt -->
        <div class="border-t border-white/5 pt-8">
          <p class="text-text-muted text-sm mb-6">
            Want to know when merch drops? Follow Arion World on YouTube and social for announcements.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a
              href="https://youtube.com/@ArionWorld"
              target="_blank"
              rel="noopener"
              class="px-6 py-2.5 bg-gold text-void font-display tracking-widest uppercase text-xs hover:bg-gold-bright transition-colors"
            >
              ▶ Subscribe on YouTube
            </a>
            <a
              href="https://instagram.com/ArionWorld"
              target="_blank"
              rel="noopener"
              class="px-6 py-2.5 border border-gold/30 text-gold font-display tracking-widest uppercase text-xs hover:border-gold transition-colors"
            >
              Follow on Instagram
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Info strip -->
  <section class="border-t border-white/5 bg-ash/50">
    <div class="max-w-6xl mx-auto px-6 py-12 grid sm:grid-cols-3 gap-8 text-center">
      <div>
        <p class="font-display text-gold text-xs tracking-widest uppercase mb-2">Print-on-Demand</p>
        <p class="text-text-dim text-sm">Made only when ordered — zero waste, zero upfront cost.</p>
      </div>
      <div>
        <p class="font-display text-gold text-xs tracking-widest uppercase mb-2">Ships Worldwide</p>
        <p class="text-text-dim text-sm">Fulfilled and shipped from local facilities globally.</p>
      </div>
      <div>
        <p class="font-display text-gold text-xs tracking-widest uppercase mb-2">Episode Art</p>
        <p class="text-text-dim text-sm">Each design comes directly from a key scene in the story.</p>
      </div>
    </div>
  </section>

</Layout>
