---
import ChatWidget from '../components/ChatWidget.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Arion World — An epic anime-style fantasy story spanning broken timelines.', ogImage } = Astro.props;
const siteTitle = title === 'Arion World' ? title : `${title} — Arion World`;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Source+Serif+4:ital,wght@0,300;0,400;1,300;1,400&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body class="bg-void text-text-primary font-body antialiased min-h-screen">

    <!-- Subtle grain overlay -->
    <div class="fixed inset-0 opacity-[0.03] pointer-events-none bg-[url('/noise.svg')] z-50"></div>

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-40 border-b border-white/5 bg-void/90 backdrop-blur-sm">
      <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-16">
        <a href="/" class="font-display text-gold text-lg tracking-widest uppercase hover:text-gold-bright transition-colors">
          Arion World
        </a>
        <div class="flex items-center gap-8 text-sm tracking-wider uppercase text-text-muted">
          {[
            ['/world', 'World'],
            ['/characters', 'Characters'],
            ['/episodes', 'Episodes'],
            ['/mysteries', 'Mysteries'],
            ['/merch', 'Merch'],
          ].map(([href, label]) => (
            <a
              href={href}
              class={`transition-colors ${currentPath.startsWith(href) ? 'text-gold' : 'hover:text-text-primary'}`}
            >
              {label}
            </a>
          ))}
          <a href="https://youtube.com/@ArionWorld" target="_blank" rel="noopener"
             class="text-gold hover:text-gold-bright transition-colors">▶ Watch</a>
        </div>
      </div>
    </nav>

    <!-- Main content -->
    <main class="pt-16">
      <slot />
    </main>

    <!-- Chat widget (floating FAQ, bottom-right) -->
    <ChatWidget />

    <!-- Footer -->
    <footer class="mt-32 border-t border-white/5 py-12">
      <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4 text-text-dim text-sm">
        <p class="font-display tracking-widest uppercase text-xs">Arion World</p>
        <p class="italic">"Where every truth is a lie waiting to be remembered."</p>
        <div class="flex gap-6">
          <a href="https://youtube.com/@ArionWorld" target="_blank" rel="noopener" class="hover:text-text-muted transition-colors">YouTube</a>
          <a href="https://tiktok.com/@ArionWorld" target="_blank" rel="noopener" class="hover:text-text-muted transition-colors">TikTok</a>
          <a href="https://instagram.com/ArionWorld" target="_blank" rel="noopener" class="hover:text-text-muted transition-colors">Instagram</a>
        </div>
      </div>
      <div class="max-w-6xl mx-auto px-6 mt-6 pt-6 border-t border-white/5 text-center">
        <p class="text-text-dim text-xs">
          © {new Date().getFullYear()} Arion World. All rights reserved.
          All characters, story, lore, world-building, skill systems, and related content are original intellectual property.
          Unauthorised reproduction, adaptation, or commercial use is prohibited.
        </p>
      </div>
    </footer>
  </body>
</html>
