# ── Arion World Publishing Pipeline — Environment Variables ──────────────────
# Copy this file to .env and fill in your keys.
# In GitHub Actions, set these as repository Secrets (Settings → Secrets).

# ── Story Generation ──────────────────────────────────────────────────────────
# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Voice Narration ───────────────────────────────────────────────────────────
# ElevenLabs API key — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=...
# Voice ID — pick from your ElevenLabs library or clone a custom voice
# Example narrator voices: pNInz6obpgDQGcFmaJgB (Adam), EXAVITQu4vr4xnSDxMaL (Bella)
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── Image Generation ──────────────────────────────────────────────────────────
# Replicate API token — https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...

# ── YouTube Publishing ────────────────────────────────────────────────────────
# Google Cloud Console — create OAuth 2.0 credentials for YouTube Data API v3
# Then run the one-time auth script: python src/youtube_auth.py
YOUTUBE_CLIENT_ID=...apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_REFRESH_TOKEN=...

# ── Facebook & Instagram Publishing ──────────────────────────────────────────
# Meta Developer Portal — https://developers.facebook.com
# Requires: Facebook Page, Instagram Business account linked to that page
# Generate a long-lived Page Access Token (expires ~60 days, refresh before then)
FACEBOOK_PAGE_ID=...
FACEBOOK_ACCESS_TOKEN=...
INSTAGRAM_ACCOUNT_ID=...

# ── TikTok Publishing ─────────────────────────────────────────────────────────
# TikTok Developer Portal — https://developers.tiktok.com
# Create an app with Content Posting API access
# Access tokens expire — implement refresh before expiry
TIKTOK_ACCESS_TOKEN=...

# ── Optional: Instagram video hosting ────────────────────────────────────────
# Instagram requires a public URL to pull the trailer video from.
# After creating the trailer, upload it somewhere public and set this URL.
# Options: GitHub Releases asset, Cloudflare R2, AWS S3 public bucket
TRAILER_PUBLIC_URL=https://...
